{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WishperType",
  "version": "0.1.2",
  "identifier": "com.wishper.type",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "label": "main",
        "title": "WishperType Settings",
        "url": "setup.html",
        "width": 520,
        "height": 520,
        "resizable": false,
        "visible": false,
        "center": true
      },
      {
        "label": "capsule",
        "title": "WishperType",
        "url": "index.html",
        "width": 340,
        "height": 76,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
