# Shared secret for /transcribe_pcm_chunk — leave empty to disable (LAN testing only).
API_KEY=

# Dashboard cookie signing — change this on the VPS.
SESSION_SECRET=change-me-in-production

# Set to true only when the dashboard is served over HTTPS.
COOKIE_SECURE=false

# SQLite — file is created on the server volume, never committed to git.
DATABASE_PATH=./data/wishpertype.db
DATABASE_URL=file:./data/wishpertype.db

# Whisper — base.en is a good default for CPU VPS speed; medium.en for accuracy.
WHISPER_MODEL=base.en
WHISPER_THREADS=4
WHISPER_LANGUAGE=en
WHISPER_SERVER_ENABLED=true
WHISPER_STREAM_CHUNK_SEC=5
WHISPER_STREAM_OVERLAP_SEC=1

# Host port mapped to container :3003
BACKEND_PORT=3003

# Comma-separated CORS origins (desktop webview + local tools)
CORS_ORIGIN=tauri://localhost,http://tauri.localhost,http://localhost:1420,http://localhost:3003,https://whisper.the10x.xyz
