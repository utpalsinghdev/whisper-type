# Shared secret — leave empty to disable auth (LAN testing only).
API_KEY=

# Whisper
WHISPER_MODEL=base.en
WHISPER_THREADS=4
WHISPER_LANGUAGE=en

# Host port mapped to container :3000
BACKEND_PORT=3000

# Comma-separated CORS origins (desktop webview + local tools)
CORS_ORIGIN=tauri://localhost,http://tauri.localhost,http://localhost:1420,http://localhost:3000
